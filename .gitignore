# Clean Seed public outbox safety ignores

# Secrets / tokens
TOKEN.txt
token.txt
*TOKEN*
*Token*
*token*
*.token
*.key
*.pem
*.pfx
*.p12
*.env
.env
.env.*
*secret*
*SECRET*
*password*
*PASSWORD*
*credential*
*CREDENTIAL*

# Local/private clutter
desktop.ini
Thumbs.db
*.tmp
*.bak
*.old

# Explicitly excluded cleanup lanes
*Shed*
*shed*
*SHED*
*Bridge*
*bridge*
*BRIDGE*

# Local-only source custody routed from parent drop zone
MULE_LOCAL_ONLY/ROOT_TANSCRIPTS_LOCAL_ONLY_20260524_100700/

# MAIL_ROOM runtime payloads are local by default.
# Commit protocol, docs, and tools. Do not accidentally commit fresh inbox payloads.
MAIL_ROOM/INCOMING_PACKAGES/*
MAIL_ROOM/DELIVERED/*
MAIL_ROOM/PROCESSED/*
MAIL_ROOM/REJECTED/*
MAIL_ROOM/LETTER_DROP/*
MAIL_ROOM/LETTER_DROP_PROCESSED/*
MAIL_ROOM/LETTER_DROP_REJECTED/*
MAIL_ROOM/CHAT_REPLY_HOLD/*
