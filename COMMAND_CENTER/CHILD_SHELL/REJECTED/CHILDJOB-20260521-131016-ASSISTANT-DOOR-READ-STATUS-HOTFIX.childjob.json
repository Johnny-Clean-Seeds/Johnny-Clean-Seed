$Raw = Get-Clipboard -Raw
if ([string]::IsNullOrWhiteSpace($Raw)) { throw "Clipboard is empty. Copy the JSON probe first." }

$Root123 = "$env:USERPROFILE\Desktop\123"
$CC = Join-Path $Root123 "COMMAND_CENTER"
$Child = Join-Path $CC "CHILD_SHELL"
$Dropzone = Join-Path $Child "DROPZONE"
$Outbox = Join-Path $Child "OUTBOX"
$Watcher = Join-Path $Child "WATCHER"
$Runners = Join-Path $Child "RUNNERS"

$Job = $Raw | ConvertFrom-Json -Depth 20
$JobId = [string]$Job.job_id
$JobPath = Join-Path $Dropzone "$JobId.childjob.json"
$ReceiptPath = Join-Path $Outbox "$JobId.receipt.txt"

if (Test-Path $JobPath) { throw "Job already exists: $JobPath" }
if (Test-Path $ReceiptPath) { throw "Receipt already exists: $ReceiptPath" }

$EnsureWatcher = Join-Path $Watcher "ENSURE_CHILD_SHELL_WATCHER_RUNNING.ps1"
$StartWatcher = Join-Path $Watcher "START_CHILD_SHELL_WATCHER.ps1"
$Dispatcher = Join-Path $Runners "RUN_CHILD_SHELL_DISPATCH_ONCE.ps1"

if (Test-Path $EnsureWatcher) {
    & powershell -NoProfile -ExecutionPolicy Bypass -File $EnsureWatcher | Out-Host
} elseif (Test-Path $StartWatcher) {
    & powershell -NoProfile -ExecutionPolicy Bypass -File $StartWatcher | Out-Host
}

$Raw | Set-Content -LiteralPath $JobPath -Encoding UTF8

$Deadline = (Get-Date).AddSeconds(15)
while ((Get-Date) -lt $Deadline) {
    if (Test-Path $ReceiptPath) { break }
    Start-Sleep -Seconds 1
}

if (-not (Test-Path $ReceiptPath)) {
    & powershell -NoProfile -ExecutionPolicy Bypass -File $Dispatcher | Out-Host
}

if (Test-Path $ReceiptPath) {
    $Hash = (Get-FileHash -LiteralPath $ReceiptPath -Algorithm SHA256).Hash
    Write-Host "XxXxX ===== COPY BLOCK TO CHAT START ===== XxXxX"
    Write-Host "ASSISTANT DOOR TEST PROBE PASS"
    Write-Host "Job ID: $JobId"
    Write-Host "Job path: $JobPath"
    Write-Host "Receipt: $ReceiptPath"
    Write-Host "Receipt SHA256: $Hash"
    Write-Host "XxXxX ===== COPY BLOCK TO CHAT END ===== XxXxX"
} else {
    Write-Host "XxXxX ===== COPY BLOCK TO CHAT START ===== XxXxX"
    Write-Host "ASSISTANT DOOR TEST PROBE PARTIAL / NO RECEIPT"
    Write-Host "Job ID: $JobId"
    Write-Host "Job path: $JobPath"
    Write-Host "Expected receipt: $ReceiptPath"
    Write-Host "XxXxX ===== COPY BLOCK TO CHAT END ===== XxXxX"
}
